# CVD Risk Intelligence Platform — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ─────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────
CVD_PLATFORM_SECRET=change-this-to-a-strong-random-secret-in-production

# ─────────────────────────────────────────────
# DATASET
# ─────────────────────────────────────────────
DATASET_DIR=cvd risk dataset
PRIMARY_TARGET_COLUMN=cardio

# ─────────────────────────────────────────────
# MODEL SETTINGS
# ─────────────────────────────────────────────
MODEL_MIN_ROC_AUC=0.75
RANDOM_SEED=42
TEST_SIZE=0.20
CV_FOLDS=5

# ─────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─────────────────────────────────────────────
# OPTIONAL: VECTOR DB
# ─────────────────────────────────────────────
# CHROMADB_PATH=./outputs/09_vector_db/chroma
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# ─────────────────────────────────────────────
# OPTIONAL: LLM (for RAG Agent)
# ─────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────
# OPTIONAL: GRAPH DB
# ─────────────────────────────────────────────
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=

# ─────────────────────────────────────────────
# DEPLOYMENT
# ─────────────────────────────────────────────
DEPLOYMENT_ENV=development
API_PORT=8000
API_HOST=0.0.0.0

# ─────────────────────────────────────────────
# COMPLIANCE
# ─────────────────────────────────────────────
COMPLIANCE_REGION=AU
HEALTHCARE_STANDARD=APP
ENCRYPTION_AT_REST=true
AUDIT_TRAIL_ENABLED=true
PII_REDACTION_ENABLED=true
